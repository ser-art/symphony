{
  "name": "symphony-ts",
  "version": "0.1.0",
  "description": "Symphony TypeScript - Agent orchestration service",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --compile --outfile bin/symphony",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@linear/sdk": "^76.0.0",
    "chokidar": "^5.0.0",
    "liquidjs": "^10.24.0",
    "yaml": "^2.8.2"
  }
}
